<?xml version="1.0" encoding="utf-8" ?>
<log4net>
  <!-- Route Adobe SDK log output to the console at WARN level only.
       This suppresses the verbose INFO/DEBUG chatter from the SDK
       while still surfacing genuine errors. -->
  <appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender">
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="[Adobe SDK] %level %logger - %message%newline" />
    </layout>
    <filter type="log4net.Filter.LevelRangeFilter">
      <levelMin value="WARN" />
    </filter>
  </appender>

  <root>
    <level value="WARN" />
    <appender-ref ref="ConsoleAppender" />
  </root>
</log4net>
