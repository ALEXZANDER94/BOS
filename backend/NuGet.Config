<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Project-level NuGet config for Mari's Portal.

    The machine-level NuGet.Config restricts package source mapping to only
    System.* and Microsoft.* packages from nuget.org. This project-level config
    adds a wildcard pattern so that all third-party packages (ElectronNET.API,
    PdfPig, QuestPDF, Google.Apis.Auth, etc.) can be resolved from nuget.org.

    This file only affects this project directory and does not change the
    machine-level configuration.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
